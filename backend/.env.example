#
# AsystQA Zero Trust Security Configuration
# Copy this file to .env and customize for your environment
#

# ============== Application Settings ==============
APP_NAME=AsystQA Backend
API_PREFIX=/api/v1
ENVIRONMENT=development  # development, staging, production
DEBUG=true

# ============== Security ==============
AUTH_REQUIRED=false  # Set true to require bearer auth for API routes

# JWT Settings (Generate with: python scripts/generate_keys.py --output-dir .\keys)
JWT_ALGORITHM=RS256
# Base64-encode the PEM files before putting them in .env.
# PowerShell:
# [Convert]::ToBase64String([IO.File]::ReadAllBytes("keys\jwt_private.pem"))
JWT_PRIVATE_KEY=
# [Convert]::ToBase64String([IO.File]::ReadAllBytes("keys\jwt_public.pem"))
JWT_PUBLIC_KEY=

# Token lifetimes (in minutes/hours)
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for data at rest (32 bytes base64)
# Generated by scripts/generate_keys.py as keys\encryption.key
ENCRYPTION_KEY=

# HMAC secrets for tamper-evident audit and memory storage.
# AUDIT_INTEGRITY_SECRET is generated as keys\integrity.key.
AUDIT_INTEGRITY_SECRET=
MEMORY_INTEGRITY_SECRET=

# ============== Multi-Factor Authentication ==============
MFA_REQUIRED=false  # Set to true to enforce MFA for all users

# ============== Key Management ==============
# HashiCorp Vault integration (optional)
KEY_VAULT_URL=
KEY_VAULT_TOKEN=

# ============== Rate Limiting ==============
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100

# ============== Data Storage ==============
DATA_DIR=./data

# ============== Agent Resilience ==============
PIPELINE_TIMEOUT=30
AGENT_RETRY_ATTEMPTS=2
AGENT_TIMEOUT_SECONDS=10
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
CIRCUIT_BREAKER_RESET_SECONDS=30

# ============== Audit Logging ==============
AUDIT_LOG_DIR=./logs/audit
AUDIT_REMOTE_SIEM=false  # Forward logs to remote SIEM
AUDIT_SIEM_URL=

# ============== Security Headers ==============
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE=31536000  # 1 year
CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'
DOCS_CSP_POLICY=default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: https://fastapi.tiangolo.com; font-src 'self' data: https://cdn.jsdelivr.net; connect-src 'self'

# ============== Network Settings ==============
# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# For production, specify exact origins

# ============== Monitoring ==============
# SIEM integration (Elasticsearch, Splunk, etc.)
ELASTICSEARCH_URL=
PROMETHEUS_MULTIPROC_DIR=/tmp

# ============== Development/Testing ==============
# Development secret (for encrypted storage when no key provided)
# CHANGE THIS IN PRODUCTION!
DEV_SECRET=change-me-secret-in-production

# ============== Database (Future) ==============
# When migrating to PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost/asystqa
